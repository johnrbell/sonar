# Sonar (standalone) — environment variables. All are OPTIONAL.
# Copy to `.env` and edit as needed. The app runs with zero configuration.

# Shared password gate (default: "john").
SONAR_PASSWORD=john

# Opaque value stored in the session cookie. Change this to invalidate all
# existing sessions. Not the password itself.
SONAR_SESSION_SECRET=sonar-session-v1

# Optional: enable AI clustering mode. Without this, the app always uses the
# built-in local (TF-IDF) clustering. Supply your own key to try AI mode.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Persistence (Vercel Postgres) ---
# Provided automatically when you attach a Postgres store to the Vercel project.
# For local dev, run `vercel env pull .env.development.local` to fetch it.
# POSTGRES_URL=postgres://...

# --- Slack integration ---
# Bot User OAuth Token (xoxb-...). Get it from your Slack app's
# "OAuth & Permissions" page after installing the app to your workspace.
# Required for the bot to read/send messages, join channels, and read files.
# SLACK_BOT_TOKEN=xoxb-...
#
# Signing Secret from the app's "Basic Information" page. Used to verify that
# inbound requests to /api/slack/events actually come from Slack.
# SLACK_SIGNING_SECRET=...
